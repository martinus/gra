def parse_args() -> argparse.Namespace:
    root = expand_path(git_output(["config", "--get", "gra.root"]) or FALLBACK_ROOT)

    parser = argparse.ArgumentParser(
        description=__doc__, formatter_class=argparse.RawDescriptionHelpFormatter
    )
    parser.add_argument(
        "-q", "--quiet", action="store_true", help="do not print status information"
    )
    parser.add_argument(
        "-v", "--version", action="version", version="%(prog)s " + __version__
    )

    subparsers = parser.add_subparsers(required=True, dest="cmd", title="commands")
    clone_parser = subparsers.add_parser(
        "clone",
        formatter_class=argparse.RawTextHelpFormatter,
        help="clone a remote repository",
        description=f"Clone a repository into '{root}/<name>/<default-branch>'.",
    )
    clone_parser.add_argument("url", help="git repository URL to clone")
    clone_parser.add_argument("--name", help="local repository name under the gra root")
    clone_parser.add_argument(
        "--no-submodules", action="store_true", help="skip fetching submodules"
    )
    clone_parser.set_defaults(
        handler=lambda args: clone(args.url, args.name, args.root, not args.no_submodules)
    )

    ls_parser = subparsers.add_parser(
        "ls",
        formatter_class=argparse.RawTextHelpFormatter,
        help="list repositories and worktrees under the gra root",
        description=f"List repositories and worktrees under '{root}'.",
    )
    ls_parser.set_defaults(handler=lambda args: print_repositories(args.root))

    cd_parser = subparsers.add_parser(
        "cd",
        formatter_class=argparse.RawTextHelpFormatter,
        help="select a worktree path with fzf",
        description=(
            "Select a worktree under the gra root with fzf and print its path.\n"
            "Use 'eval \"$(gra shell bash)\"' to make 'gra cd' change directories."
        ),
    )
    cd_parser.set_defaults(handler=lambda args: print_cd_target(args.root))

    code_parser = subparsers.add_parser(
        "code",
        formatter_class=argparse.RawTextHelpFormatter,
        help="select a worktree with fzf and open it in Visual Studio Code",
        description=(
            "Select a worktree under the gra root with fzf and open it in Visual Studio Code.\n"
            "Pass SSH_TARGET, such as HOST or USER@HOST, to open a remote worktree with VS Code Remote SSH."
        ),
    )
    code_parser.add_argument(
        "ssh_target",
        nargs="?",
        metavar="SSH_TARGET",
        help="SSH target to query, for example HOST or USER@HOST",
    )
    code_parser.add_argument(
        "--worktrees-json",
        action="store_true",
        help=argparse.SUPPRESS,
    )
    code_parser.set_defaults(
        handler=lambda args: (
            print_worktree_picker_rows(args.root)
            if args.worktrees_json
            else open_code_target(args.root, args.ssh_target)
        )
    )

    shell_parser = subparsers.add_parser(
        "shell",
        formatter_class=argparse.RawTextHelpFormatter,
        help="print shell integration code",
        description="Print shell integration code for eval.",
    )
    shell_parser.add_argument("shell", choices=["bash"], help="shell to initialize")
    shell_parser.set_defaults(handler=lambda args: print_shell_init(args.shell))

    wt_parser = subparsers.add_parser(
        "wt",
        formatter_class=argparse.RawTextHelpFormatter,
        help="create, update, or list worktrees for the current repository",
        description=(
            "Without arguments, list worktrees for the current repository.\n"
            "With BRANCH, create or update a worktree under '<repo>/wt'.\n"
            "Use --name for a reusable worktree folder such as 'review'."
        ),
    )
    wt_parser.add_argument("branch", nargs="?", help="branch to check out")
    wt_parser.add_argument("--name", help="folder name under the repository wt directory")
    wt_parser.set_defaults(
        handler=lambda args: (
            wt_create(args.branch, args.name)
            if args.branch
            else print_repo_worktrees()
        )
    )

    clean_parser = subparsers.add_parser(
        "clean",
        formatter_class=argparse.RawTextHelpFormatter,
        help="report or remove worktrees that are safe to delete",
        description=(
            f"Classify worktrees in every repository under '{root}':\n"
            "  keep  - default checkout, dirty, or has commits not in origin's default branch\n"
            "  safe  - clean and fully merged into origin's default branch\n"
            "  prune - the worktree path no longer exists on disk\n"
            "Without --yes, only prints the tables."
        ),
    )
    clean_parser.add_argument(
        "--yes", action="store_true", help="actually remove safe worktrees and prune missing ones"
    )
    clean_parser.add_argument(
        "--no-fetch", action="store_true", help="skip 'git fetch --prune origin' before classifying"
    )
    clean_parser.set_defaults(handler=lambda args: clean(args.root, args.yes, not args.no_fetch))

    args = parser.parse_args()
    args.root = root
    return args


def main() -> None:
    global _quiet

    args = parse_args()
    _quiet = args.quiet
    args.handler(args)


if __name__ == "__main__":
    os.environ["GIT_ASK_YESNO"] = "1"
    main()
