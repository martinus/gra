#!/usr/bin/env python3

"""gra - Git Repo Admin

A tiny clone helper that puts repositories under a flat ~/git layout:

    ~/git/<repo>/<default-branch>
    ~/git/<repo>/wt

Only the `clone`, `cd`, `init`, `ls`, and `wt` commands are supported.
"""

__version__ = "0.7.0"

import argparse
import os
import re
import shutil
import subprocess
import sys
from pathlib import Path
from typing import NoReturn
from urllib.parse import urlparse


# gra owns this layout. Git commands are anchored in one checkout, but paths are
# resolved relative to the repository container that holds the default checkout
# and the shared worktree directory.
FALLBACK_ROOT = "~/git"
WORKTREE_DIR = "wt"

# Claude may create its own temporary worktrees inside a checkout. Keep those
# local-only directories out of `git status` without changing tracked files.
CLAUDE_WORKTREES_EXCLUDE = ".claude/worktrees/"

_quiet = False
_use_color = sys.stdout.isatty() and "NO_COLOR" not in os.environ
if _use_color:
    BLUE, GREEN, RED, YELLOW, CYAN, BOLD, DIM = (
        "\x1b[38;5;4m",
        "\x1b[38;5;2m",
        "\x1b[38;5;1m",
        "\x1b[38;5;3m",
        "\x1b[38;5;6m",
        "\x1b[1m",
        "\x1b[2m",
    )
    ENDC = "\033[0m"
else:
    BLUE = GREEN = RED = YELLOW = CYAN = BOLD = DIM = ENDC = ""


# ---------------------------------------------------------------------------
# Process and output helpers
# ---------------------------------------------------------------------------


def expand_path(path: str) -> Path:
    return Path(os.path.expandvars(os.path.expanduser(path)))


def log(msg: str, color: str = BLUE) -> None:
    if not _quiet:
        print(f"{color}{msg}{ENDC}")


def style(text: str, *colors: str) -> str:
    code = "".join(colors)
    return f"{code}{text}{ENDC}" if code else text


def fail(msg: str) -> NoReturn:
    print(f"{RED}ERROR: {msg}{ENDC}", file=sys.stderr)
    sys.exit(1)


def ask_yes_no(question: str) -> bool:
    print(f"{question} [y/N] ", end="", file=sys.stderr, flush=True)
    answer = sys.stdin.readline()
    if not answer:
        print(file=sys.stderr)
        return False
    return answer.strip().lower() in {"y", "yes"}


def run_git(args: list[str | Path], *, cwd: Path | None = None) -> None:
    """Run a Git command that should own its normal terminal output."""
    subprocess.run(["git", *args], cwd=cwd, check=True)


def git_output(args: list[str | Path], *, cwd: Path | None = None) -> str | None:
    """Run a quiet Git probe; return None when Git cannot answer it."""
    try:
        return subprocess.check_output(
            ["git", *args], cwd=cwd, encoding="utf-8", stderr=subprocess.DEVNULL
        ).strip()
    except subprocess.CalledProcessError:
        return None


def git_config(name: str) -> str | None:
    return git_output(["config", "--get", name])


# ---------------------------------------------------------------------------
# Remote URL and local name helpers
# ---------------------------------------------------------------------------


def url_parts(url: str) -> list[str]:
    """Return path-like URL parts for HTTPS, SSH scp-like, and local paths."""
    if match := re.match(r"[^@/]+@[^:]+:(.+)$", url):
        path = match.group(1)
    else:
        parsed = urlparse(url)
        path = parsed.path if parsed.scheme else url
    return [part for part in path.rstrip("/").removesuffix(".git").split("/") if part]


def repo_name_from_url(url: str) -> str:
    parts = url_parts(url)
    if not parts:
        raise ValueError(f"cannot derive repository name from '{url}'")
    return parts[-1]


def owner_from_url(url: str) -> str | None:
    parts = url_parts(url)
    if len(parts) >= 2:
        return parts[-2]
    return None


def validate_repo_name(name: str) -> None:
    if not re.fullmatch(r"[A-Za-z0-9._-]+", name):
        fail(
            f"invalid repository name '{name}'; use only letters, numbers, dots, underscores, and dashes"
        )
    if name in {".", ".."} or name.startswith("."):
        fail(f"invalid repository name '{name}'")


def origin_url(checkout: Path) -> str | None:
    if not (checkout / ".git").exists():
        return None
    return git_output(["config", "--get", "remote.origin.url"], cwd=checkout)


def existing_origin(container: Path) -> str | None:
    """Find an origin URL inside a repo container for collision messages."""
    if not container.is_dir():
        return None
    for child in sorted(container.iterdir(), key=lambda path: path.name):
        if child.is_dir():
            origin = origin_url(child)
            if origin:
                return origin
    return None


def suggest_name(url: str, repo_name: str) -> str | None:
    owner = owner_from_url(url)
    if not owner:
        return None
    suggestion = f"{repo_name}-{owner}"
    return suggestion if suggestion != repo_name else None


def clone_collision_error(url: str, container: Path, repo_name: str) -> None:
    lines = [
        f"local repository name '{repo_name}' already exists",
        "",
        "Existing:",
        f"  path:   {container}",
    ]
    if origin := existing_origin(container):
        lines.append(f"  origin: {origin}")
    lines += [
        "",
        "Requested:",
        f"  origin: {url}",
    ]
    if suggestion := suggest_name(url, repo_name):
        lines += [
            "",
            "Use a distinct name, for example:",
            f"  gra clone {url} --name {suggestion}",
        ]
    fail("\n".join(lines))


def checkout_dir_name(checkout: Path) -> str:
    """Name the first checkout after the remote's default branch."""
    branch = git_output(["branch", "--show-current"], cwd=checkout)
    name = (branch or "checkout").replace("/", "-")
    return name if re.fullmatch(r"[A-Za-z0-9._-]+", name) else "checkout"


# ---------------------------------------------------------------------------
# gra layout discovery
# ---------------------------------------------------------------------------


def validate_worktree_name(name: str) -> None:
    if not re.fullmatch(r"[A-Za-z0-9._-]+", name):
        fail(
            f"invalid worktree name '{name}'; use only letters, numbers, dots, underscores, and dashes"
        )
    if name in {".", ".."} or name.startswith("."):
        fail(f"invalid worktree name '{name}'")


def worktree_name_from_ref(ref: str) -> str:
    """Derive a filesystem-safe worktree folder from a branch name."""
    name = re.sub(r"[^A-Za-z0-9._-]+", "-", ref.replace("/", "-")).strip("-")
    if not name or name in {".", ".."} or name.startswith("."):
        fail(f"cannot derive worktree name from '{ref}'")
    return name


def git_toplevel(path: Path) -> Path | None:
    """Return the enclosing Git worktree root, if path is inside one."""
    checkout = git_output(["rev-parse", "--show-toplevel"], cwd=path)
    return Path(checkout) if checkout else None


def is_git_worktree(path: Path) -> bool:
    return git_output(["rev-parse", "--is-inside-work-tree"], cwd=path) == "true"


def checkout_in_container(container: Path) -> Path | None:
    """Pick a real checkout that can anchor repo-wide Git commands.

    This is what lets `gra wt` run from the repo container or from the `wt`
    folder, which are gra layout directories but not Git worktrees themselves.
    """
    if not container.is_dir():
        return None

    for child in sorted(container.iterdir(), key=lambda path: path.name):
        if child.name != WORKTREE_DIR and child.is_dir() and is_git_worktree(child):
            return child

    wt_root = container / WORKTREE_DIR
    if wt_root.is_dir():
        for child in sorted(wt_root.iterdir(), key=lambda path: path.name):
            if child.is_dir() and is_git_worktree(child):
                return child

    return None


def checkout_from_layout(path: Path) -> Path | None:
    """Walk upward looking for a gra repo container or its `wt` directory."""
    for candidate in [path, *path.parents]:
        if candidate.name == WORKTREE_DIR:
            checkout = checkout_in_container(candidate.parent)
            if checkout:
                return checkout

        if (candidate / WORKTREE_DIR).is_dir():
            checkout = checkout_in_container(candidate)
            if checkout:
                return checkout

    return None


def current_checkout() -> Path:
    """Resolve the checkout used to run Git for the current gra command."""
    cwd = Path.cwd()
    checkout = git_toplevel(cwd) or checkout_from_layout(cwd)
    if not checkout:
        fail("gra wt must be run from inside a gra repository")
    return checkout


def repo_container(checkout: Path) -> Path:
    """Return the gra repo container for a checkout or nested worktree."""
    if checkout.parent.name == WORKTREE_DIR:
        return checkout.parent.parent
    return checkout.parent


# ---------------------------------------------------------------------------
# Git branch and worktree probes
# ---------------------------------------------------------------------------


def local_branch_exists(checkout: Path, branch: str) -> bool:
    return (
        git_output(["show-ref", "--verify", "--quiet", f"refs/heads/{branch}"], cwd=checkout)
        is not None
    )


def remote_branch_exists(checkout: Path, branch: str) -> bool:
    return (
        git_output(
            ["show-ref", "--verify", "--quiet", f"refs/remotes/origin/{branch}"],
            cwd=checkout,
        )
        is not None
    )


def ref_exists(checkout: Path, ref: str) -> bool:
    return (
        git_output(["rev-parse", "--verify", "--quiet", f"{ref}^{{commit}}"], cwd=checkout)
        is not None
    )


def remote_default_branch(checkout: Path) -> str | None:
    origin_head = git_output(
        ["symbolic-ref", "--quiet", "--short", "refs/remotes/origin/HEAD"],
        cwd=checkout,
    )
    if origin_head and ref_exists(checkout, origin_head):
        return origin_head

    for branch in ["main", "master"]:
        if remote_branch_exists(checkout, branch):
            return f"origin/{branch}"

    return None


def worktree_paths(checkout: Path) -> list[Path]:
    output = git_output(["worktree", "list", "--porcelain"], cwd=checkout) or ""
    paths = []
    for line in output.splitlines():
        if line.startswith("worktree "):
            paths.append(Path(line.removeprefix("worktree ")))
    return paths


def worktree_ref(path: Path) -> str:
    if not path.exists():
        return "missing"

    branch = git_output(["branch", "--show-current"], cwd=path)
    if branch:
        return branch

    exact = git_output(["describe", "--all", "--exact-match", "HEAD"], cwd=path)
    if exact:
        return exact.removeprefix("heads/").removeprefix("remotes/")

    short_head = git_output(["rev-parse", "--short", "HEAD"], cwd=path)
    return short_head or "detached"


def worktree_status(path: Path) -> str:
    if not path.exists():
        return "missing"
    status = git_output(["status", "--porcelain"], cwd=path)
    return "dirty" if status else "clean"


def status_label(status: str) -> str:
    labels = {
        "clean": "✓ clean",
        "dirty": "● dirty",
        "missing": "× missing",
    }
    return labels.get(status, status)


def relative_worktree_path(container: Path, path: Path) -> str:
    try:
        return path.relative_to(container).as_posix()
    except ValueError:
        return str(path)


def repository_checkouts(root: Path) -> list[tuple[Path, Path]]:
    """Return gra repo containers and one checkout that can query each repo."""
    if not root.is_dir():
        return []

    repositories = []
    for container in sorted(root.iterdir(), key=lambda path: path.name):
        if not container.is_dir():
            continue
        checkout = checkout_in_container(container)
        if checkout:
            repositories.append((container, checkout))
    return repositories


def worktree_rows(
    checkout: Path, container: Path, current: Path | None
) -> list[list[str]]:
    rows = []
    for path in worktree_paths(checkout):
        marker = "▶" if current and path.resolve() == current else ""
        rows.append(
            [
                marker,
                relative_worktree_path(container, path),
                worktree_ref(path),
                status_label(worktree_status(path)),
            ]
        )
    return rows


def table_cell(header: str, value: str) -> str:
    if not value:
        return value
    if not header:
        return style(value, BLUE, BOLD)
    if header == "REPOSITORY":
        return style(value, BLUE, BOLD)
    if header == "WORKTREE" and value.startswith(f"{WORKTREE_DIR}/"):
        return style(value, DIM)
    if header == "REF":
        return style(value, CYAN)
    if header == "REMOTE":
        return style(value, DIM)
    if header == "STATUS":
        if value.startswith("✓"):
            return style(value, GREEN)
        if value.startswith("●"):
            return style(value, YELLOW)
        if value.startswith("×"):
            return style(value, RED)
    return value


def table_line(headers: list[str], values: list[str], widths: list[int]) -> str:
    cells = []
    for header, value, width in zip(headers, values, widths):
        cells.append(table_cell(header, value) + " " * (width - len(value)))
    return "  ".join(cells).rstrip()


def print_table(headers: list[str], rows: list[list[str]], *, indent: str = "") -> None:
    columns = [
        index
        for index, header in enumerate(headers)
        if header or any(row[index] for row in rows)
    ]
    headers = [headers[index] for index in columns]
    rows = [[row[index] for index in columns] for row in rows]

    widths = [len(header) for header in headers]
    for row in rows:
        for index, value in enumerate(row):
            widths[index] = max(widths[index], len(value))

    print(indent + style(table_line(headers, headers, widths), BOLD))
    for row in rows:
        print(indent + table_line(headers, row, widths))


# ---------------------------------------------------------------------------
# clone command
# ---------------------------------------------------------------------------


def add_local_excludes(checkout: Path) -> None:
    """Install local ignore rules for tool-managed paths in the main checkout."""
    exclude = checkout / ".git" / "info" / "exclude"
    if not exclude.is_file():
        return

    lines = exclude.read_text().splitlines()
    if CLAUDE_WORKTREES_EXCLUDE not in lines:
        with exclude.open("a", encoding="utf-8") as file:
            if lines and lines[-1] != "":
                file.write("\n")
            file.write(f"{CLAUDE_WORKTREES_EXCLUDE}\n")


def clone(url: str, name: str | None, root: Path, with_submodules: bool) -> None:
    """Clone into gra's repo container and prepare its worktree directory."""
    try:
        repo_name = name or repo_name_from_url(url)
    except ValueError as error:
        fail(str(error))
    validate_repo_name(repo_name)

    container = root / repo_name
    if container.exists():
        clone_collision_error(url, container, repo_name)

    tmp_checkout = container / ".clone"
    try:
        container.mkdir(parents=True)
        cmd: list[str | Path] = ["clone"]
        if with_submodules:
            cmd += ["--recurse-submodules", "--remote-submodules"]
        cmd += [url, tmp_checkout]

        log(f"Cloning '{url}' into '{container}'")
        run_git(cmd)

        checkout = container / checkout_dir_name(tmp_checkout)
        if checkout.exists():
            fail(f"cannot move checkout to '{checkout}' because it already exists")
        tmp_checkout.rename(checkout)
        (container / WORKTREE_DIR).mkdir()
        add_local_excludes(checkout)
        log(f"created '{checkout}'", GREEN)
    except Exception:
        if tmp_checkout.exists():
            shutil.rmtree(tmp_checkout)
        if container.exists() and not any(container.iterdir()):
            container.rmdir()
        raise


# ---------------------------------------------------------------------------
# ls command
# ---------------------------------------------------------------------------


def print_repositories(root: Path) -> None:
    """Show every gra repository and every Git worktree under the gra root."""
    repositories = repository_checkouts(root)
    print(f"Root: {root}")
    if not repositories:
        print("No repositories found.")
        return

    active_checkout = git_toplevel(Path.cwd())
    current = active_checkout.resolve() if active_checkout else None
    rows = []
    for container, checkout in repositories:
        repo_rows = worktree_rows(checkout, container, current)
        remote = origin_url(checkout) or "-"
        for index, row in enumerate(repo_rows):
            rows.append(
                [
                    row[0],
                    container.name if index == 0 else "",
                    *row[1:],
                    remote if index == 0 else "",
                ]
            )

    print(f"Repositories: {len(repositories)}  Worktrees: {len(rows)}")
    print()
    print_table(["", "REPOSITORY", "WORKTREE", "REF", "STATUS", "REMOTE"], rows)


# ---------------------------------------------------------------------------
# cd command
# ---------------------------------------------------------------------------


def worktree_choices(root: Path) -> list[str]:
    """Return fzf input lines with the absolute path in the first field."""
    headers = ["REPOSITORY", "WORKTREE", "REF"]
    rows: list[tuple[Path, list[str]]] = []
    for container, checkout in repository_checkouts(root):
        for path in worktree_paths(checkout):
            if not path.is_dir():
                continue
            rows.append(
                (
                    path,
                    [
                        container.name,
                        relative_worktree_path(container, path),
                        worktree_ref(path),
                    ],
                )
            )

    widths = [len(header) for header in headers]
    for _path, values in rows:
        for index, value in enumerate(values):
            widths[index] = max(widths[index], len(value))

    choices = []
    for path, values in rows:
        label = "  ".join(
            value.ljust(width) for value, width in zip(values, widths)
        ).rstrip()
        choices.append(f"{path}\t{label}")
    return choices


def worktree_picker_header(choices: list[str]) -> str:
    """Return a header aligned with the visible fzf choice text."""
    headers = ["REPOSITORY", "WORKTREE", "REF"]
    widths = [len(header) for header in headers]
    for choice in choices:
        _path, label = choice.split("\t", 1)
        values = re.split(r" {2,}", label)
        for index, value in enumerate(values):
            widths[index] = max(widths[index], len(value))

    return "  ".join(
        header.ljust(width) for header, width in zip(headers, widths)
    ).rstrip()


def print_cd_target(root: Path) -> None:
    """Select a worktree with fzf and print the selected absolute path."""
    choices = worktree_choices(root)
    if not choices:
        fail(f"no worktrees found under '{root}'")

    if not shutil.which("fzf"):
        fail("fzf is required for 'gra cd'")

    result = subprocess.run(
        [
            "fzf",
            "--height=80%",
            "--layout=reverse",
            "--border",
            "--no-sort",
            "--prompt=gra cd> ",
            f"--header={worktree_picker_header(choices)}",
            "--delimiter=\t",
            "--with-nth=2",
        ],
        input="\n".join(choices) + "\n",
        stdout=subprocess.PIPE,
        encoding="utf-8",
        check=False,
    )
    if result.returncode != 0:
        sys.exit(result.returncode)

    selected = result.stdout.rstrip("\n")
    if not selected:
        sys.exit(1)
    print(selected.split("\t", 1)[0])


# ---------------------------------------------------------------------------
# init command
# ---------------------------------------------------------------------------


BASH_INIT = r'''gra() {
    if [[ ${1-} == cd ]]; then
        shift
        local target
        target="$(command gra cd "$@")" || return
        [[ -n $target ]] && builtin cd "$target"
    else
        command gra "$@"
    fi
}
'''


def print_shell_init(shell: str) -> None:
        """Print shell integration code for eval."""
        if shell == "bash":
                print(BASH_INIT, end="")
                return
        fail(f"unsupported shell '{shell}'")


# ---------------------------------------------------------------------------
# wt command
# ---------------------------------------------------------------------------


def print_worktrees() -> None:
    """Show the repo's worktrees using paths relative to the gra container."""
    checkout = current_checkout()
    container = repo_container(checkout)
    active_checkout = git_toplevel(Path.cwd())
    current = active_checkout.resolve() if active_checkout else None
    print_table(["", "WORKTREE", "REF", "STATUS"], worktree_rows(checkout, container, current))


def create_missing_branch(checkout: Path, branch: str) -> None:
    start_point = remote_default_branch(checkout)
    if not start_point:
        fail(f"cannot resolve branch '{branch}' and cannot find origin's default branch")

    if not ask_yes_no(f"Branch '{branch}' does not exist. Create it from '{start_point}'?"):
        fail(f"branch '{branch}' was not created")

    run_git(["branch", branch, start_point], cwd=checkout)
    log(f"created branch '{branch}' from '{start_point}'", GREEN)


def add_attached_worktree(checkout: Path, target: Path, branch: str) -> None:
    """Create a worktree that checks out branch, tracking origin if needed."""
    if local_branch_exists(checkout, branch):
        run_git(["worktree", "add", target, branch], cwd=checkout)
        return

    if remote_branch_exists(checkout, branch):
        run_git(
            ["worktree", "add", "--track", "-b", branch, target, f"origin/{branch}"],
            cwd=checkout,
        )
        return

    create_missing_branch(checkout, branch)
    run_git(["worktree", "add", target, branch], cwd=checkout)


def switch_to_branch(checkout: Path, target: Path, branch: str) -> None:
    """Reuse an existing worktree by switching it to branch."""
    if local_branch_exists(checkout, branch):
        run_git(["switch", branch], cwd=target)
        return

    if remote_branch_exists(checkout, branch):
        run_git(["switch", "--track", f"origin/{branch}"], cwd=target)
        return

    create_missing_branch(checkout, branch)
    run_git(["switch", branch], cwd=target)


def wt_create(branch: str, name: str | None) -> None:
    """Create or update a worktree under the repo's `wt` directory."""
    checkout = current_checkout()
    container = repo_container(checkout)
    wt_root = container / WORKTREE_DIR
    target_name = name or worktree_name_from_ref(branch)
    validate_worktree_name(target_name)

    target = wt_root / target_name
    if target.exists():
        if not target.is_dir() or not is_git_worktree(target):
            fail(f"cannot use '{target}' because it is not a Git worktree")
        log(f"Switching '{target}' to '{branch}'")
        switch_to_branch(checkout, target, branch)
        log(f"updated '{target}'", GREEN)
        return

    wt_root.mkdir(exist_ok=True)
    log(f"Creating worktree '{target}' for branch '{branch}'")
    add_attached_worktree(checkout, target, branch)
    log(f"created '{target}'", GREEN)


# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------


def parse_args() -> argparse.Namespace:
    root = expand_path(git_config("gra.root") or FALLBACK_ROOT)

    parser = argparse.ArgumentParser(
        description=__doc__, formatter_class=argparse.RawDescriptionHelpFormatter
    )
    parser.add_argument(
        "-q", "--quiet", action="store_true", help="do not print status information"
    )
    parser.add_argument(
        "-v", "--version", action="version", version="%(prog)s " + __version__
    )

    subparsers = parser.add_subparsers(required=True, dest="cmd", title="commands")
    clone_parser = subparsers.add_parser(
        "clone",
        formatter_class=argparse.RawTextHelpFormatter,
        help="clone a remote repository",
        description=f"Clone a repository into '{root}/<name>/<default-branch>'.",
    )
    clone_parser.add_argument("url", help="git repository URL to clone")
    clone_parser.add_argument("--name", help="local repository name under the gra root")
    clone_parser.add_argument(
        "--no-submodules", action="store_true", help="skip fetching submodules"
    )

    subparsers.add_parser(
        "ls",
        formatter_class=argparse.RawTextHelpFormatter,
        help="list repositories and worktrees under the gra root",
        description=f"List repositories and worktrees under '{root}'.",
    )

    subparsers.add_parser(
        "cd",
        formatter_class=argparse.RawTextHelpFormatter,
        help="select a worktree path with fzf",
        description=(
            "Select a worktree under the gra root with fzf and print its path.\n"
            "Use 'eval \"$(gra init bash)\"' to make 'gra cd' change directories."
        ),
    )

    init_parser = subparsers.add_parser(
        "init",
        formatter_class=argparse.RawTextHelpFormatter,
        help="print shell integration code",
        description="Print shell integration code for eval.",
    )
    init_parser.add_argument("shell", choices=["bash"], help="shell to initialize")

    wt_parser = subparsers.add_parser(
        "wt",
        formatter_class=argparse.RawTextHelpFormatter,
        help="list, create, or update worktrees under the repository wt directory",
        description=(
            "List worktrees for the current repository, or create a worktree under '<repo>/wt'.\n"
            "Use --name for a reusable worktree folder such as 'review'."
        ),
    )
    wt_parser.add_argument(
        "branch",
        nargs="?",
        help="existing branch to check out; omitted to list worktrees",
    )
    wt_parser.add_argument("--name", help="folder name under the repository wt directory")

    args = parser.parse_args()
    args.root = root
    return args


def main() -> None:
    global _quiet

    args = parse_args()
    _quiet = args.quiet
    if args.cmd == "clone":
        clone(args.url, args.name, args.root, not args.no_submodules)
    elif args.cmd == "ls":
        print_repositories(args.root)
    elif args.cmd == "cd":
        print_cd_target(args.root)
    elif args.cmd == "init":
        print_shell_init(args.shell)
    elif args.cmd == "wt":
        if args.branch:
            wt_create(args.branch, args.name)
        elif args.name:
            fail("--name requires a branch")
        else:
            print_worktrees()


if __name__ == "__main__":
    os.environ["GIT_ASK_YESNO"] = "1"
    main()
