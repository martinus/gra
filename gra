def is_merged_into(path: Path, ref: str) -> bool:
    """Return True if HEAD at path is reachable from ref."""
    result = subprocess.run(
        ["git", "merge-base", "--is-ancestor", "HEAD", ref],
        cwd=path,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        check=False,
    )
    return result.returncode == 0


def classify_worktree(
    path: Path, default_path: Path | None, default_ref: str | None
) -> tuple[str, str]:
    """Return (verdict, reason) for a worktree path. Verdict is keep/safe/prune."""
    if not path.exists():
        return ("prune", "missing path")
    if default_path and path.resolve() == default_path.resolve():
        return ("keep", "default checkout")
    if git_output(["status", "--porcelain"], cwd=path):
        return ("keep", "uncommitted changes")
    if not default_ref:
        return ("keep", "origin default branch unknown")
    if is_merged_into(path, default_ref):
        return ("safe", f"merged into {default_ref}")
    return ("keep", f"has commits not in {default_ref}")


def clean_repository_entries(
    container: Path, checkout: Path, fetch: bool
) -> list[tuple[Path, Path, str, str, str, str]]:
    """Classify worktrees in one repository.

    Returns rows of (container, path, ref_label, status, verdict, reason).
    """
    if fetch:
        subprocess.run(
            ["git", "fetch", "--prune", "origin"],
            cwd=checkout,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            check=False,
        )

    default_path = default_checkout(container)
    default_ref = remote_default_branch(checkout)
    entries = []
    for path in worktree_paths(checkout):
        verdict, reason = classify_worktree(path, default_path, default_ref)
        entries.append(
            (container, path, worktree_ref(path), fmt_worktree_status(path), verdict, reason)
        )
    return entries


def apply_clean(checkout: Path, entries: list[tuple[Path, Path, str, str, str, str]]) -> None:
    """Remove safe worktrees and prune missing entries for one repository."""
    has_missing = False
    for _container, path, _ref, _status, verdict, _reason in entries:
        if verdict == "prune":
            has_missing = True
            continue
        if verdict != "safe":
            continue
        branch = git_output(["branch", "--show-current"], cwd=path)
        log(f"Removing worktree '{path}'")
        run_git(["worktree", "remove", path], cwd=checkout)
        if branch and local_branch_exists(checkout, branch):
            deleted = subprocess.run(
                ["git", "branch", "-d", branch],
                cwd=checkout,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                check=False,
            )
            if deleted.returncode == 0:
                log(f"deleted branch '{branch}'", GREEN)
    if has_missing:
        log(f"Pruning missing worktree entries in '{checkout}'")
        run_git(["worktree", "prune"], cwd=checkout)


def clean(root: Path, yes: bool, fetch: bool) -> None:
    """Report cleanable worktrees across every gra repository under root."""
    repositories = repository_checkouts(root)
    print(f"Root: {root}")
    if not repositories:
        print("No repositories found.")
        return

    if fetch:
        log(f"Fetching origin for {len(repositories)} repositories")

    repo_entries = [
        (checkout, clean_repository_entries(container, checkout, fetch))
        for container, checkout in repositories
    ]

    rows = []
    for _checkout, entries in repo_entries:
        for index, (container, path, ref_label, status, verdict, reason) in enumerate(entries):
            rows.append(
                [
                    container.name if index == 0 else "",
                    relative_worktree_path(container, path),
                    ref_label,
                    status,
                    verdict,
                    reason,
                ]
            )

    total_safe = sum(1 for _c, entries in repo_entries for e in entries if e[4] == "safe")
    total_missing = sum(1 for _c, entries in repo_entries for e in entries if e[4] == "prune")

    print(f"Repositories: {len(repositories)}  Worktrees: {len(rows)}")
    print()
    print_table(
        ["REPOSITORY", "WORKTREE", "REF", "STATUS", "VERDICT", "REASON"], rows
    )

    print()
    if not total_safe and not total_missing:
        log("Nothing to clean.", GREEN)
        return

    if not yes:
        actions = []
        if total_safe:
            actions.append(f"remove {total_safe} worktree(s)")
        if total_missing:
            entries_word = "entry" if total_missing == 1 else "entries"
            actions.append(f"prune {total_missing} missing {entries_word}")
        log(f"Dry run. Re-run with --yes to {' and '.join(actions)}.", YELLOW)
        return

    for checkout, entries in repo_entries:
        if any(e[4] in {"safe", "prune"} for e in entries):
            apply_clean(checkout, entries)

    print()
    log(
        f"Removed {total_safe} worktree(s); pruned missing entries in {total_missing} place(s).",
        GREEN,
    )


