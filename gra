def local_worktree_picker_rows(root: Path) -> list[tuple[str, list[str]]]:
    """Return local worktree picker rows under the gra root."""
    return [
        (str(path), [container.name, relative_worktree_path(container, path), worktree_ref(path)])
        for container, checkout in repository_checkouts(root)
        for path in worktree_paths(checkout)
        if path.is_dir()
    ]


def worktree_picker_choices(rows: list[tuple[str, list[str]]]) -> tuple[list[str], str]:
    """Return fzf input lines and an aligned header."""
    headers = ["REPOSITORY", "WORKTREE", "REF"]

    widths = column_widths(headers, [values for _, values in rows], include_headers=False)
    choices = [f"{target}\t{padded_line(values, widths)}" for target, values in rows]
    return choices, padded_line(headers, widths)


def select_worktree_from_rows(
    rows: list[tuple[str, list[str]]], command: str, source: str
) -> str:
    """Select a worktree with fzf and return the selected absolute path."""
    choices, header = worktree_picker_choices(rows)
    if not choices:
        fail(f"no worktrees found {source}")

    if not shutil.which("fzf"):
        fail(f"fzf is required for 'gra {command}'")

    result = subprocess.run(
        [
            "fzf",
            "--height=80%",
            "--layout=reverse",
            "--border",
            "--tiebreak=begin,index",
            f"--prompt=gra {command}> ",
            f"--header={header}",
            "--delimiter=\t",
            "--with-nth=2",
        ],
        input="\n".join(choices) + "\n",
        stdout=subprocess.PIPE,
        encoding="utf-8",
        check=False,
    )
    if result.returncode != 0:
        sys.exit(result.returncode)

    selected = result.stdout.rstrip("\n")
    if not selected:
        sys.exit(1)
    return selected.split("\t", 1)[0]


def pick_local_worktree(root: Path, command: str) -> str:
    """Select a local worktree with fzf and return the selected absolute path."""
    return select_worktree_from_rows(
        local_worktree_picker_rows(root), command, f"under '{root}'"
    )


def print_cd_target(root: Path) -> None:
    """Select a worktree with fzf and print the selected absolute path."""
    print(pick_local_worktree(root, "cd"))


def print_worktree_picker_rows(root: Path) -> None:
    """Print local worktree picker rows as JSON for remote gra callers."""
    print(json.dumps(local_worktree_picker_rows(root)))


REMOTE_GRA_WORKTREES_COMMAND = (
    'PATH="$HOME/.local/bin:$PATH"; export PATH; exec gra code --worktrees-json'
)


def remote_worktree_picker_rows(ssh_target: str) -> list[tuple[str, list[str]]]:
    """Return worktree picker rows from gra installed on a remote SSH target."""
    if not ssh_target or ssh_target.startswith("-"):
        fail(f"invalid SSH target '{ssh_target}'")
    if not shutil.which("ssh"):
        fail("ssh is required for 'gra code SSH_TARGET'")

    result = subprocess.run(
        ["ssh", "-T", ssh_target, REMOTE_GRA_WORKTREES_COMMAND],
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        encoding="utf-8",
        check=False,
    )
    if result.returncode != 0:
        detail = result.stderr.strip()
        fail(f"ssh to '{ssh_target}' failed" + (f": {detail}" if detail else ""))

    try:
        return [(path, values) for path, values in json.loads(result.stdout)]
    except json.JSONDecodeError as error:
        fail(f"could not parse worktrees from '{ssh_target}': {error}")
    except (TypeError, ValueError):
        fail(f"invalid worktree data from '{ssh_target}'")


def open_code_target(root: Path, ssh_target: str | None) -> None:
    """Select a worktree with fzf and open it in Visual Studio Code."""
    code = shutil.which("code")
    if not code:
        fail("code is required for 'gra code'")

    if ssh_target:
        target = select_worktree_from_rows(
            remote_worktree_picker_rows(ssh_target), "code", f"on '{ssh_target}'"
        )
        command = [code, "--remote", f"ssh-remote+{ssh_target}", target]
    else:
        target = pick_local_worktree(root, "code")
        command = [code, target]
    log(shlex.join(command))
    result = subprocess.run(command, check=False)
    if result.returncode != 0:
        sys.exit(result.returncode)


